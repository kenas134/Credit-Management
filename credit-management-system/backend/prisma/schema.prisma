generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  phone         String         @unique
  email         String?        @unique
  password      String
  role          Role           @default(OWNER)
  isActive      Boolean        @default(true)
  refreshToken  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  auditLogs     AuditLog[]
  notifications Notification[]
  shop          Shop?

  @@map("users")
}

model Shop {
  id        String     @id @default(cuid())
  name      String
  address   String?
  phone     String?
  logoUrl   String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  ownerId   String     @unique
  customers Customer[]
  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("shops")
}

model Customer {
  id             String         @id @default(cuid())
  fullName       String
  nickname       String?
  phone          String
  alternatePhone String?
  address        String?
  photoUrl       String?
  trustScore     Float          @default(5.0)
  riskLevel      RiskLevel      @default(LOW)
  isActive       Boolean        @default(true)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  shopId         String
  creditAccount  CreditAccount?
  shop           Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  notifications  Notification[]

  @@unique([phone, shopId])
  @@map("customers")
}

model CreditAccount {
  id             String        @id @default(cuid())
  creditLimit    Float         @default(5000.00)
  currentBalance Float         @default(0.00)
  totalPaid      Float         @default(0.00)
  totalCredited  Float         @default(0.00)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  customerId     String        @unique
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  transactions   Transaction[]

  @@map("credit_accounts")
}

model Transaction {
  id              String            @id @default(cuid())
  type            TransactionType
  amount          Float
  description     String?
  dueDate         DateTime?
  status          TransactionStatus @default(PENDING)
  reference       String?
  receiptUrl      String?
  isVoid          Boolean           @default(false)
  voidReason      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  creditAccountId String
  payments        Payment[]
  creditAccount   CreditAccount     @relation(fields: [creditAccountId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Payment {
  id            String        @id @default(cuid())
  amount        Float
  paymentDate   DateTime      @default(now())
  method        PaymentMethod @default(CASH)
  reference     String?
  receiptUrl    String?
  notes         String?
  isVoid        Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  transactionId String
  transaction   Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Notification {
  id         String             @id @default(cuid())
  type       NotificationType
  title      String
  message    String
  status     NotificationStatus @default(UNREAD)
  sentAt     DateTime?
  readAt     DateTime?
  metadata   Json?
  createdAt  DateTime           @default(now())
  userId     String?
  customerId String?
  customer   Customer?          @relation(fields: [customerId], references: [id])
  user       User?              @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model SyncQueue {
  id        String    @id @default(cuid())
  operation String
  entity    String
  payload   Json
  synced    Boolean   @default(false)
  syncedAt  DateTime?
  retries   Int       @default(0)
  error     String?
  createdAt DateTime  @default(now())

  @@map("sync_queue")
}

enum Role {
  OWNER
  STAFF
  ADMIN
}

enum TransactionType {
  CREDIT
  PAYMENT
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  WRITTEN_OFF
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK_TRANSFER
  OTHER
}

enum NotificationType {
  PAYMENT_REMINDER
  OVERDUE_ALERT
  PAYMENT_RECEIVED
  CREDIT_LIMIT_WARNING
  SYSTEM
}

enum NotificationStatus {
  UNREAD
  READ
  SENT
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}
