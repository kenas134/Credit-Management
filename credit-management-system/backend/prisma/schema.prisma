// prisma/schema.prisma
// Credit Management System — Full Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  STAFF
  ADMIN
}

enum TransactionType {
  CREDIT    // customer takes goods on credit
  PAYMENT   // customer repays
  ADJUSTMENT // manual balance correction
}

enum TransactionStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  WRITTEN_OFF
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK_TRANSFER
  OTHER
}

enum NotificationType {
  PAYMENT_REMINDER
  OVERDUE_ALERT
  PAYMENT_RECEIVED
  CREDIT_LIMIT_WARNING
  SYSTEM
}

enum NotificationStatus {
  UNREAD
  READ
  SENT
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  phone        String   @unique
  email        String?  @unique
  password     String
  role         Role     @default(OWNER)
  isActive     Boolean  @default(true)
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  shop         Shop?
  auditLogs    AuditLog[]
  notifications Notification[]

  @@map("users")
}

model Shop {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId   String    @unique
  customers Customer[]

  @@map("shops")
}

model Customer {
  id             String    @id @default(cuid())
  fullName       String
  nickname       String?
  phone          String
  alternatePhone String?
  address        String?
  photoUrl       String?
  trustScore     Float     @default(5.0) // 0.0 - 10.0
  riskLevel      RiskLevel @default(LOW)
  isActive       Boolean   @default(true)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  shop           Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId         String
  creditAccount  CreditAccount?
  notifications  Notification[]

  @@unique([phone, shopId])
  @@map("customers")
}

model CreditAccount {
  id             String   @id @default(cuid())
  creditLimit    Float    @default(5000.00)
  currentBalance Float    @default(0.00)  // total outstanding debt
  totalPaid      Float    @default(0.00)
  totalCredited  Float    @default(0.00)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId     String        @unique
  transactions   Transaction[]

  @@map("credit_accounts")
}

model Transaction {
  id          String            @id @default(cuid())
  type        TransactionType
  amount      Float
  description String?
  dueDate     DateTime?
  status      TransactionStatus @default(PENDING)
  reference   String?           // e.g., "INV-001"
  receiptUrl  String?
  isVoid      Boolean           @default(false)
  voidReason  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  creditAccount   CreditAccount @relation(fields: [creditAccountId], references: [id], onDelete: Cascade)
  creditAccountId String
  payments        Payment[]

  @@map("transactions")
}

model Payment {
  id            String        @id @default(cuid())
  amount        Float
  paymentDate   DateTime      @default(now())
  method        PaymentMethod @default(CASH)
  reference     String?       // mobile money transaction ref
  receiptUrl    String?
  notes         String?
  isVoid        Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String

  @@map("payments")
}

model Notification {
  id         String             @id @default(cuid())
  type       NotificationType
  title      String
  message    String
  status     NotificationStatus @default(UNREAD)
  sentAt     DateTime?
  readAt     DateTime?
  metadata   Json?              // extra data like transaction id
  createdAt  DateTime           @default(now())

  // Relations
  user       User?     @relation(fields: [userId], references: [id])
  userId     String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // CREATE_CUSTOMER, RECORD_PAYMENT, etc.
  entity    String   // Customer, Transaction, Payment, etc.
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  // Relations
  user      User?   @relation(fields: [userId], references: [id])
  userId    String?

  @@map("audit_logs")
}

model SyncQueue {
  id          String   @id @default(cuid())
  operation   String   // CREATE, UPDATE, DELETE
  entity      String
  payload     Json
  synced      Boolean  @default(false)
  syncedAt    DateTime?
  retries     Int      @default(0)
  error       String?
  createdAt   DateTime @default(now())

  @@map("sync_queue")
}
