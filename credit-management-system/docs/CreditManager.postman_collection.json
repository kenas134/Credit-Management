{
  "info": {
    "name": "Credit Management System API",
    "description": "Complete API collection for the Credit Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "customerId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Kwame Asante\",\n  \"phone\": \"+233501234567\",\n  \"shopName\": \"Asante Mini-Market\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+233501234567\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/auth/change-password",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"newPassword456\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "List Customers",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/customers?page=1&limit=20",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "status", "value": "ACTIVE", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.customer?.id) {",
                  "  pm.collectionVariables.set('customerId', res.data.customer.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/customers",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Ama Boateng\",\n  \"phone\": \"+233244123456\",\n  \"email\": \"ama@email.com\",\n  \"address\": \"Kumasi, Ghana\",\n  \"creditLimit\": 800\n}"
            }
          }
        },
        {
          "name": "Get Customer",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/customers/{{customerId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Credit Limit",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/customers/{{customerId}}/credit-limit",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"creditLimit\": 1500\n}" }
          }
        },
        {
          "name": "Refresh Risk Score",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/customers/{{customerId}}/refresh-risk",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Credits",
      "item": [
        {
          "name": "Issue Credit",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/credits",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"amount\": 250.00,\n  \"description\": \"Groceries - rice, sugar, oil\",\n  \"dueDate\": \"2025-12-31\"\n}"
            }
          }
        },
        {
          "name": "Get Ledger",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/credits/{{customerId}}/ledger",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Account Summary",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/credits/{{customerId}}/summary",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Record Payment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/payments",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"amount\": 100.00,\n  \"notes\": \"Cash payment received\"\n}"
            }
          }
        },
        {
          "name": "Payment History",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/payments/history",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Outstanding Balances",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reports/outstanding",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Aging Analysis",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reports/aging",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "KPIs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reports/kpis",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Payment Trend",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reports/payment-trend",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/notifications",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Mark All As Read",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/notifications/read-all",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
